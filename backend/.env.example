# ── Groq API ─────────────────────────────────────────────────
# Get your free key at https://console.groq.com
# Without this key, DiagramAI runs in offline/fallback mode (still works, limited prompts)
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default model
# DIAGRAMAI_MODEL=openai/gpt-oss-120b

# ── Database ────────────────────────────────────────────────
# Production: use a free Neon PostgreSQL database (https://neon.tech)
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Local dev: leave blank to use SQLite (./diagramai.db)
# DATABASE_URL=sqlite:///./diagramai.db

# ── Session signing ─────────────────────────────────────────
# Signs the auth cookie. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# CHANGE THIS IN PRODUCTION. The default below is INSECURE.
SESSION_SECRET=dev-secret-change-me-in-prod

# ── Google OAuth ────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match exactly:
#   https://your-domain/api/auth/google/callback
# Leave both blank to disable Google login (the UI auto-hides the button).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Admin panel ─────────────────────────────────────────────
# The Google account with this email gets access to /admin
# Only one admin supported. Leave blank to disable the panel entirely.
ADMIN_EMAIL=you@example.com
